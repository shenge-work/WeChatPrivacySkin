<Window x:Class="WeChatPrivacySkin.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="微信隐私皮肤"
        Width="520"
        Height="470"
        MinWidth="460"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7F8">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="微信隐私皮肤"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#1B2428"/>
            <TextBlock Text="不修改微信本体的背景、主题和企业隐私遮罩工具"
                       Margin="0,6,0,0"
                       Foreground="#607078"/>
        </StackPanel>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#DDE5E8"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="128"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="隐私模式" VerticalAlignment="Center" Foreground="#334148"/>
                <CheckBox x:Name="PrivacyCheckBox"
                          Grid.Column="1"
                          Content="开启后仅遮罩非当前微信窗口"
                          VerticalAlignment="Center"
                          Checked="PrivacyCheckBox_OnChanged"
                          Unchecked="PrivacyCheckBox_OnChanged"/>

                <TextBlock Grid.Row="2" Text="主题" VerticalAlignment="Center" Foreground="#334148"/>
                <ComboBox x:Name="ThemeComboBox"
                          Grid.Row="2"
                          Grid.Column="1"
                          SelectionChanged="ThemeComboBox_OnSelectionChanged"/>

                <TextBlock Grid.Row="4" Text="遮罩强度" VerticalAlignment="Center" Foreground="#334148"/>
                <DockPanel Grid.Row="4" Grid.Column="1">
                    <TextBlock x:Name="OpacityValueText"
                               Width="54"
                               DockPanel.Dock="Right"
                               TextAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="#607078"/>
                    <Slider x:Name="OpacitySlider"
                            Minimum="0.35"
                            Maximum="0.95"
                            TickFrequency="0.05"
                            ValueChanged="OpacitySlider_OnValueChanged"/>
                </DockPanel>

                <TextBlock Grid.Row="6" Text="置顶遮罩" VerticalAlignment="Center" Foreground="#334148"/>
                <CheckBox x:Name="TopmostCheckBox"
                          Grid.Row="6"
                          Grid.Column="1"
                          Content="优先显示在微信窗口上方，适合共享整个屏幕"
                          VerticalAlignment="Center"
                          Checked="TopmostCheckBox_OnChanged"
                          Unchecked="TopmostCheckBox_OnChanged"/>

                <TextBlock Grid.Row="8" Text="背景图片" VerticalAlignment="Center" Foreground="#334148"/>
                <DockPanel Grid.Row="8" Grid.Column="1">
                    <Button Content="选择..." DockPanel.Dock="Right" Margin="10,0,0,0" Click="ChooseBackground_OnClick"/>
                    <Button Content="清除" DockPanel.Dock="Right" Margin="10,0,0,0" Click="ClearBackground_OnClick"/>
                    <TextBlock x:Name="BackgroundPathText"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="#607078"/>
                </DockPanel>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Background="#EAF2EF"
                BorderBrush="#C9DCD5"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <StackPanel>
                <TextBlock Text="快捷键"
                           FontWeight="SemiBold"
                           Foreground="#25343A"/>
                <TextBlock Text="Ctrl + Alt + P：开启或关闭隐私模式"
                           Margin="0,8,0,0"
                           Foreground="#53666D"/>
                <TextBlock Text="Ctrl + Alt + T：切换主题"
                           Margin="0,5,0,0"
                           Foreground="#53666D"/>
                <TextBlock Text="说明：工具只识别微信窗口，不读取聊天内容，不修改微信安装目录。"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap"
                           Foreground="#53666D"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="打开配置目录" Click="OpenSettingsFolder_OnClick"/>
            <Button Content="关闭" Margin="12,0,0,0" IsDefault="True" Click="Close_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
