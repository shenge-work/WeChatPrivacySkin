<Window x:Class="WeChatPrivacySkin.ManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="微信隐私皮肤管理平台"
        Width="920"
        Height="660"
        MinWidth="820"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F6">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#172322" Padding="18">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                    <TextBlock Text="WeChat Privacy"
                               Foreground="#F4FFF9"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="隐私守护与沉浸皮肤"
                               Foreground="#A9C7BD"
                               Margin="0,6,0,0"
                               FontSize="12"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock x:Name="TrayHintText"
                               Text="右键托盘图标打开本平台"
                               TextWrapping="Wrap"
                               Foreground="#A9C7BD"
                               FontSize="12"
                               Margin="0,0,0,12"/>
                    <Button Content="退出工具" Click="Exit_OnClick"/>
                </StackPanel>

                <ListBox x:Name="NavigationList"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#F4FFF9"
                         SelectionChanged="NavigationList_OnSelectionChanged">
                    <ListBoxItem Tag="Overview" Content="总览"/>
                    <ListBoxItem Tag="Privacy" Content="隐私场景"/>
                    <ListBoxItem Tag="Themes" Content="主题皮肤"/>
                    <ListBoxItem Tag="Hotkeys" Content="快捷键"/>
                    <ListBoxItem Tag="Rules" Content="窗口规则"/>
                    <ListBoxItem Tag="About" Content="关于"/>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel>
                <StackPanel>
                    <TextBlock x:Name="PageTitleText"
                               Text="总览"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="#172322"/>
                    <TextBlock x:Name="PageSubtitleText"
                               Text="查看当前保护状态和快捷操作"
                               Margin="0,6,0,0"
                               Foreground="#60736E"/>
                </StackPanel>
                <Border x:Name="StatusPill"
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Padding="14,8"
                        CornerRadius="16">
                    <TextBlock x:Name="StatusPillText"
                               FontWeight="SemiBold"/>
                </Border>
            </DockPanel>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <StackPanel x:Name="OverviewSection">
                        <UniformGrid Columns="3" Rows="1">
                            <Border Background="White" BorderBrush="#DCE7E3" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="保护模式" Foreground="#60736E"/>
                                    <TextBlock x:Name="OverviewModeText" Margin="0,10,0,0" FontSize="22" FontWeight="SemiBold" Foreground="#172322"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="#DCE7E3" BorderThickness="1" CornerRadius="8" Padding="18" Margin="6,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="检测到微信窗口" Foreground="#60736E"/>
                                    <TextBlock x:Name="WindowCountText" Margin="0,10,0,0" FontSize="22" FontWeight="SemiBold" Foreground="#172322"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="#DCE7E3" BorderThickness="1" CornerRadius="8" Padding="18" Margin="12,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="当前主题" Foreground="#60736E"/>
                                    <TextBlock x:Name="OverviewThemeText" Margin="0,10,0,0" FontSize="22" FontWeight="SemiBold" Foreground="#172322"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Background="#EAF5F1" BorderBrush="#CDE2DA" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="快捷操作" FontWeight="SemiBold" Foreground="#172322"/>
                                <WrapPanel Margin="0,14,0,0">
                                    <Button Content="日常保护" Margin="0,0,10,10" Click="DailyMode_OnClick"/>
                                    <Button Content="会议共享" Margin="0,0,10,10" Click="MeetingMode_OnClick"/>
                                    <Button Content="离席保护" Margin="0,0,10,10" Click="AwayMode_OnClick"/>
                                    <Button Content="快速净屏" Margin="0,0,10,10" Click="CleanMode_OnClick"/>
                                    <Button Content="专注聊天" Margin="0,0,10,10" Click="FocusMode_OnClick"/>
                                </WrapPanel>
                                <TextBlock x:Name="ActiveWindowText"
                                           Margin="0,10,0,0"
                                           Foreground="#60736E"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="PrivacySection" Visibility="Collapsed">
                        <Border Background="White" BorderBrush="#DCE7E3" BorderThickness="1" CornerRadius="8" Padding="18">
                            <StackPanel>
                                <CheckBox x:Name="PrivacyEnabledCheckBox"
                                          Content="开启微信隐私守护"
                                          FontSize="15"
                                          Checked="PrivacyEnabled_OnChanged"
                                          Unchecked="PrivacyEnabled_OnChanged"/>
                                <TextBlock Text="关闭后不再创建遮罩和焦点外框。"
                                           Margin="0,8,0,0"
                                           Foreground="#60736E"/>
                            </StackPanel>
                        </Border>

                        <WrapPanel x:Name="PrivacyModePanel" Margin="0,18,0,0"/>

                        <Border Background="White" BorderBrush="#DCE7E3" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,18,0,0">
                            <StackPanel>
                                <CheckBox x:Name="TopmostCheckBox" Content="置顶遮罩，优先保护会议共享和录屏" Checked="Topmost_OnChanged" Unchecked="Topmost_OnChanged"/>
                                <CheckBox x:Name="CoverPopupsCheckBox" Content="覆盖微信通知、预览、转发、搜索等弹窗" Margin="0,10,0,0" Checked="PrivacyOption_OnChanged" Unchecked="PrivacyOption_OnChanged"/>
                                <CheckBox x:Name="MeetingWarningCheckBox" Content="会议共享模式显示单窗口共享风险提示" Margin="0,10,0,0" Checked="PrivacyOption_OnChanged" Unchecked="PrivacyOption_OnChanged"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="ThemesSection" Visibility="Collapsed">
                        <Border Background="White" BorderBrush="#DCE7E3" BorderThickness="1" CornerRadius="8" Padding="18">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="132"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="遮罩强度" VerticalAlignment="Center" Foreground="#344844"/>
                                    <DockPanel Grid.Column="1">
                                        <TextBlock x:Name="OpacityValueText" Width="58" DockPanel.Dock="Right" TextAlignment="Right" VerticalAlignment="Center" Foreground="#60736E"/>
                                        <Slider x:Name="OpacitySlider" Minimum="0.35" Maximum="0.95" TickFrequency="0.05" ValueChanged="OpacitySlider_OnValueChanged"/>
                                    </DockPanel>
                                </Grid>
                                <StackPanel Margin="0,18,0,0">
                                    <CheckBox x:Name="MotionCheckBox" Content="允许主题轻动效和装饰层" Checked="Motion_OnChanged" Unchecked="Motion_OnChanged"/>
                                    <DockPanel Margin="0,14,0,0">
                                        <Button Content="选择背景图片" DockPanel.Dock="Right" Click="ChooseBackground_OnClick"/>
                                        <Button Content="清除背景" DockPanel.Dock="Right" Margin="0,0,10,0" Click="ClearBackground_OnClick"/>
                                        <TextBlock x:Name="BackgroundPathText" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Foreground="#60736E"/>
                                    </DockPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <WrapPanel x:Name="ThemePanel" Margin="0,18,0,0"/>
                    </StackPanel>

                    <StackPanel x:Name="HotkeysSection" Visibility="Collapsed">
                        <Border Background="White" BorderBrush="#DCE7E3" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Ctrl + Alt + P：开启或关闭隐私守护" Foreground="#172322" FontSize="15"/>
                                <TextBlock Text="Ctrl + Alt + T：切换主题皮肤" Foreground="#172322" FontSize="15" Margin="0,12,0,0"/>
                                <TextBlock Text="Ctrl + Alt + L：快速净屏，再按一次回到日常保护" Foreground="#172322" FontSize="15" Margin="0,12,0,0"/>
                                <TextBlock Text="托盘图标：右键打开管理平台，双击切换隐私守护。按住 Shift 右键可打开退出兜底菜单。"
                                           TextWrapping="Wrap"
                                           Foreground="#60736E"
                                           Margin="0,18,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="RulesSection" Visibility="Collapsed">
                        <Border Background="White" BorderBrush="#DCE7E3" BorderThickness="1" CornerRadius="8" Padding="18">
                            <StackPanel>
                                <TextBlock Text="窗口识别覆盖独立聊天、主窗口、搜索、收藏、转发、文件传输、图片预览、通知和登录确认。"
                                           Foreground="#60736E"
                                           TextWrapping="Wrap"/>
                                <ItemsControl x:Name="RulesList" Margin="0,16,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="AboutSection" Visibility="Collapsed">
                        <Border Background="White" BorderBrush="#DCE7E3" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="边界说明" FontSize="18" FontWeight="SemiBold" Foreground="#172322"/>
                                <TextBlock Text="本工具不修改微信安装目录，不注入微信进程，不读取聊天内容，不截图微信窗口。"
                                           Margin="0,12,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="#60736E"/>
                                <TextBlock Text="主题皮肤是外层沉浸效果，不替换微信内部聊天气泡、消息列表或控件样式。"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="#60736E"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
