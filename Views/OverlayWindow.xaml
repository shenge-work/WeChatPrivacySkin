<Window x:Class="WeChatPrivacySkin.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        Width="420"
        Height="320">
    <Grid x:Name="Root" ClipToBounds="True" IsHitTestVisible="False">
        <Rectangle x:Name="ImageLayer" Stretch="UniformToFill"/>
        <Rectangle x:Name="PatternLayer"/>
        <Rectangle x:Name="TintLayer"/>

        <Canvas x:Name="ShapeCanvas"/>
        <Canvas x:Name="SkeletonCanvas"/>
        <Canvas x:Name="DecorationCanvas"/>
        <Canvas x:Name="SkinCanvas"/>

        <Border x:Name="CornerSticker"
                Width="118"
                Height="34"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,14,14,0"
                Padding="12,0"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <RotateTransform Angle="4"/>
            </Border.RenderTransform>
            <TextBlock x:Name="CornerStickerText"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       FontWeight="Bold"/>
        </Border>

        <Canvas x:Name="HintCanvas">
            <Border x:Name="RevealHint"
                    Padding="10,6"
                    CornerRadius="14"
                    Visibility="Collapsed">
                <TextBlock x:Name="RevealHintText"
                           FontSize="12"
                           FontWeight="SemiBold"/>
            </Border>
        </Canvas>
    </Grid>
</Window>
