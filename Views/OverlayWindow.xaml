<Window x:Class="WeChatPrivacySkin.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        Width="420"
        Height="320">
    <Grid x:Name="Root" ClipToBounds="True">
        <Rectangle x:Name="ImageLayer" Stretch="UniformToFill"/>
        <Rectangle x:Name="PatternLayer"/>
        <Rectangle x:Name="TintLayer"/>

        <Border x:Name="OuterFrame"
                Margin="6"
                BorderThickness="3"
                Background="Transparent"/>

        <Border x:Name="CornerSticker"
                Width="116"
                Height="34"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,14,14,0"
                Padding="12,0"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <RotateTransform Angle="4"/>
            </Border.RenderTransform>
            <TextBlock x:Name="CornerStickerText"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       FontWeight="Bold"/>
        </Border>

        <Border x:Name="Panel"
                Margin="22"
                Padding="22"
                CornerRadius="10"
                BorderThickness="1.2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel>
                    <Border x:Name="StatusDot"
                            Width="10"
                            Height="10"
                            CornerRadius="5"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="TitleText"
                                   Text="企业隐私模式"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="SubtitleText"
                                   Text="非当前微信窗口已脱敏"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="AvatarPlaceholder"
                            Width="72"
                            Height="72"
                            CornerRadius="12"/>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <Border x:Name="LineOne" Height="12" CornerRadius="6" Margin="0,0,44,10"/>
                        <Border x:Name="LineTwo" Height="12" CornerRadius="6" Margin="0,0,8,10"/>
                        <Border x:Name="LineThree" Height="12" CornerRadius="6" Margin="0,0,82,0"/>
                    </StackPanel>
                </Grid>

                <UniformGrid Grid.Row="3" Rows="4" Columns="1" Margin="0,22,0,0">
                    <Border x:Name="ContentLineOne" Height="11" CornerRadius="5.5" Margin="0,4,90,4"/>
                    <Border x:Name="ContentLineTwo" Height="11" CornerRadius="5.5" Margin="34,4,24,4"/>
                    <Border x:Name="ContentLineThree" Height="11" CornerRadius="5.5" Margin="0,4,120,4"/>
                    <Border x:Name="ContentLineFour" Height="11" CornerRadius="5.5" Margin="58,4,62,4"/>
                </UniformGrid>

                <TextBlock x:Name="WatermarkText"
                           Grid.Row="4"
                           Text="WeChat Privacy Skin"
                           HorizontalAlignment="Right"
                           Margin="0,18,0,0"
                           FontSize="12"
                           FontWeight="Medium"
                           Opacity="0.52"/>
            </Grid>
        </Border>
    </Grid>
</Window>
