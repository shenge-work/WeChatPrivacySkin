<Window x:Class="WeChatPrivacySkin.FocusFrameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        Width="420"
        Height="320">
    <Grid ClipToBounds="True">
        <Border x:Name="Frame"
                Margin="3"
                BorderThickness="3"
                CornerRadius="8"
                Background="Transparent"/>
    </Grid>
</Window>
